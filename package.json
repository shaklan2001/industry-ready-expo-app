{
  "name": "expo-native-tabs-template",
  "version": "1.0.0",
  "description": "A modern Expo Router template with native tabs, TypeScript, and industry-standard file structure",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios"
  },
  "keywords": [
    "expo",
    "react-native",
    "expo-router",
    "native-tabs",
    "typescript",
    "template",
    "boilerplate"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/expo-native-tabs-template.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/expo-native-tabs-template/issues"
  },
  "homepage": "https://github.com/yourusername/expo-native-tabs-template#readme",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/native": "^6.1.9",
    "expo": "~54.0.10",
    "expo-asset": "~12.0.9",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.8",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.8",
    "expo-status-bar": "~3.0.8",
    "moment": "^2.30.1",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": false
