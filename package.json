{
  "name": "industry-ready-expo-app",
  "version": "1.1.3",
  "description": "Industry-ready Expo SDK 56 template with AI context system, theme setup, TypeScript, Reanimated, and Vite-style welcome UI",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "prepublishOnly": "npm run type-check"
  },
  "keywords": [
    "expo",
    "expo-template",
    "react-native",
    "expo-router",
    "typescript",
    "eslint",
    "prettier",
    "reanimated",
    "expo-ui",
    "ai-context",
    "industry-ready",
    "production-ready",
    "modern-architecture"
  ],
  "author": "Nishant Shaklan <nishant.ns171@gmail.com> (https://www.nishantshaklan.co.in/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaklan2001/industry-ready-expo-app.git"
  },
  "bugs": {
    "url": "https://github.com/shaklan2001/industry-ready-expo-app/issues"
  },
  "homepage": "https://github.com/shaklan2001/industry-ready-expo-app#readme",
  "dependencies": {
    "@expo/ui": "~56.0.13",
    "@expo/vector-icons": "^15.0.2",
    "expo": "~56.0.4",
    "expo-asset": "~56.0.14",
    "expo-constants": "~56.0.15",
    "expo-font": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.6",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.85.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.6.2",
    "typescript": "~6.0.3"
  },
  "private": false
}
